class Book:
    def __init__(self, name: str, author: str, genre: str, year: int):
        self.name = name
        self.author = author
        self.genre = genre 
        self.year = year
        
def older_book(book1: Book, book2: Book):
    if book1.year < book2.year:
        print(f"{book1.name} is older, is was published in {book1.year}")
    elif book1.year > book2.year:
        print(f"{book2.name} is older, is was published in {book2.year}")
    else:
        print(f"{book1.name} and {book2.name} were published in {book1.year}")
